rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Fase 1 (uso interno Nox Imóveis):
    // - Leitura liberada: a TV do saguão (/tv) lê sem login (dashboards, agenda, funil).
    // - Escrita SÓ para usuários autenticados: ninguém de fora cria/edita/apaga nada.
    // Fase 2 (futuro): logar a TV num usuário próprio e restringir leituras também.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
